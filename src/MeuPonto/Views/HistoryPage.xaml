<Page
    x:Class="MeuPonto.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MeuPonto.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="24,16,24,24">

        <!-- Cabeçalho -->
        <TextBlock Text="Histórico de Registros"
                   FontSize="20" FontWeight="SemiBold"
                   Grid.Row="0" />

        <!-- Filtro e ações -->
        <StackPanel Orientation="Horizontal" Spacing="8" Grid.Row="1"
                    Margin="0,12,0,8">
            <CalendarDatePicker PlaceholderText="Filtrar por data"
                                Date="{x:Bind ViewModel.FilterDate, Mode=TwoWay}"
                                DateFormat="{}{day.integer}/{month.integer}/{year.full}"
                                MinWidth="160" />
            <Button Content="Filtrar" Command="{x:Bind ViewModel.ApplyFilterCommand}" />
            <Button Content="Limpar" Command="{x:Bind ViewModel.ClearFilterCommand}" />
            <Button Content="Abrir pasta" Command="{x:Bind ViewModel.OpenDataFolderCommand}" />
            <Button Content="Exportar CSV" Command="{x:Bind ViewModel.ExportCsvCommand}" />
        </StackPanel>

        <!-- Lista de registros -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.Records, Mode=OneWay}"
                  SelectionMode="None"
                  Margin="0,4,0,0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.Header>
                <Grid ColumnDefinitions="*,*,*,*,*,*,36" Padding="12,8"
                      Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                      CornerRadius="6,6,0,0">
                    <TextBlock Text="Data" FontSize="12" FontWeight="SemiBold" Grid.Column="0" />
                    <TextBlock Text="Entrada" FontSize="12" FontWeight="SemiBold" Grid.Column="1" />
                    <TextBlock Text="Saída" FontSize="12" FontWeight="SemiBold" Grid.Column="2" />
                    <TextBlock Text="Total" FontSize="12" FontWeight="SemiBold" Grid.Column="3" />
                    <TextBlock Text="Pausas" FontSize="12" FontWeight="SemiBold" Grid.Column="4" />
                    <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold" Grid.Column="5" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,*,*,*,*,*,36" Padding="12,6"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding Date}" FontSize="13" Grid.Column="0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding EntryTime}" FontSize="13" Grid.Column="1"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ExitTime}" FontSize="13" Grid.Column="2"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TotalWorked}" FontSize="13" FontWeight="SemiBold" Grid.Column="3"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PauseTime}" FontSize="13" Grid.Column="4"
                                   VerticalAlignment="Center" Opacity="0.7" />
                        <StackPanel Orientation="Horizontal" Spacing="6" Grid.Column="5"
                                    VerticalAlignment="Center">
                            <Border CornerRadius="10" Padding="8,3"
                                    HorizontalAlignment="Left"
                                    Background="{Binding StatusBadgeColor}">
                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" />
                            </Border>
                            <TextBlock Text="(editado)" FontSize="11" Opacity="0.5"
                                       FontStyle="Italic" VerticalAlignment="Center"
                                       Visibility="{Binding IsManuallyEdited, Converter={StaticResource BoolToVis}}"
                                       ToolTipService.ToolTip="{Binding EditedAtTooltip}" />
                        </StackPanel>
                        <Button Grid.Column="6" Padding="4" MinWidth="0" MinHeight="0"
                                Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}"
                                Tag="{Binding}"
                                Click="OnEditButtonClick"
                                ToolTipService.ToolTip="Editar registro">
                            <FontIcon Glyph="&#xE70F;" FontSize="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Rodapé -->
        <TextBlock Text="{x:Bind ViewModel.RecordCount, Mode=OneWay}"
                   FontSize="12" Opacity="0.5"
                   Grid.Row="3" Margin="0,8,0,0" />

        <!-- Dialog de edição -->
        <ContentDialog x:Name="EditDialog"
                       Title="Editar Registro"
                       PrimaryButtonText="Salvar"
                       CloseButtonText="Cancelar"
                       DefaultButton="Primary"
                       PrimaryButtonClick="OnEditDialogSave"
                       CloseButtonClick="OnEditDialogCancel">
            <StackPanel Spacing="12" MinWidth="280">
                <TextBox x:Name="EditEntryTimeBox"
                         Header="Hora de entrada (HH:mm)"
                         Text="{x:Bind ViewModel.EditEntryTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="08:00"
                         MaxLength="5"
                         TextChanged="OnEditTimeChanged" />
                <TextBox x:Name="EditExitTimeBox"
                         Header="Hora de saída (HH:mm)"
                         Text="{x:Bind ViewModel.EditExitTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="17:00"
                         MaxLength="5"
                         TextChanged="OnEditTimeChanged" />
                <TextBlock>
                    <Run Text="Total: " />
                    <Run Text="{x:Bind ViewModel.EditTotalWorked, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Text="{x:Bind ViewModel.EditValidationError, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
