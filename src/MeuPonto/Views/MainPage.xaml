<Page
    x:Class="MeuPonto.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MeuPonto.Converters"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </Page.Resources>

    <Grid Padding="24,36,24,20">
        <StackPanel Spacing="0" HorizontalAlignment="Center">

            <!-- ═══ Status badge ═══ -->
            <Border CornerRadius="12" Padding="12,5"
                    HorizontalAlignment="Center"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8"
                             Fill="#4CAF50"
                             Visibility="{x:Bind ViewModel.CanPause, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <Ellipse Width="8" Height="8"
                             Fill="#FF9800"
                             Visibility="{x:Bind ViewModel.IsPaused, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <Ellipse Width="8" Height="8"
                             Fill="#9E9E9E"
                             Visibility="{x:Bind ViewModel.IsOffDuty, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- ═══ Contador principal ═══ -->
            <TextBlock Text="{x:Bind ViewModel.ElapsedTimeText, Mode=OneWay}"
                       FontSize="48" FontWeight="Light"
                       CharacterSpacing="50"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />

            <!-- ═══ Horários de referência ═══ -->
            <StackPanel Spacing="2" HorizontalAlignment="Center" Margin="0,6,0,0">
                <TextBlock FontSize="12" Opacity="0.55" HorizontalAlignment="Center">
                    <Run Text="Entrada:" />
                    <Run Text="{x:Bind ViewModel.EntryTimeText, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock FontSize="12" Opacity="0.55" HorizontalAlignment="Center">
                    <Run Text="Saída prevista:" />
                    <Run Text="{x:Bind ViewModel.EstimatedExitText, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock FontSize="12" Opacity="0.55" HorizontalAlignment="Center">
                    <Run Text="Limite máximo:" />
                    <Run Text="{x:Bind ViewModel.MaxExitText, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Text="{x:Bind ViewModel.PauseTimeText, Mode=OneWay}"
                           FontSize="12" Opacity="0.55"
                           HorizontalAlignment="Center"
                           Foreground="#FF9800" />
            </StackPanel>

            <!-- ═══ Relógio atual ═══ -->
            <TextBlock Text="{x:Bind ViewModel.CurrentTime, Mode=OneWay}"
                       FontSize="12" Opacity="0.4"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />

            <!-- ═══ Ações ═══ -->
            <StackPanel Spacing="8" Margin="0,14,0,0" Width="260">
                <Button Content="Entrada"
                        Command="{x:Bind ViewModel.ClockInCommand}"
                        HorizontalAlignment="Stretch" Height="36"
                        Style="{StaticResource AccentButtonStyle}" />

                <Button Content="Saída"
                        Command="{x:Bind ViewModel.ClockOutCommand}"
                        HorizontalAlignment="Stretch" Height="36" />

                <Button Content="Pausar"
                        Command="{x:Bind ViewModel.PauseCommand}"
                        HorizontalAlignment="Stretch" Height="36"
                        Visibility="{x:Bind ViewModel.CanPause, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                <Button Content="Retomar"
                        Command="{x:Bind ViewModel.ResumeCommand}"
                        HorizontalAlignment="Stretch" Height="36"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="{x:Bind ViewModel.CanResume, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                <Grid ColumnDefinitions="*,8,*" Margin="0,4,0,0">
                    <Button Content="Histórico"
                            Command="{x:Bind ViewModel.OpenHistoryCommand}"
                            HorizontalAlignment="Stretch" Height="32"
                            FontSize="12"
                            Grid.Column="0" />
                    <Button Content="Configurações"
                            Command="{x:Bind ViewModel.OpenSettingsCommand}"
                            HorizontalAlignment="Stretch" Height="32"
                            FontSize="12"
                            Grid.Column="2" />
                </Grid>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
